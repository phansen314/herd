#!/usr/bin/env bash
# herd CLI wrapper — runs from the source tree, no pip install needed.
# Resolve through a possible PATH symlink (~/.local/bin/herd) to the real bin/herd.
#
# `readlink -f` is GNU-only: macOS shipped no -f until 12.3, where SELF comes back
# EMPTY, HERE resolves to the wrong directory and the import fails. herd claims
# macOS support (README, DESIGN.md#the-hooks-hookssh "bash 3.2", daemon.py's
# "Portable Linux+macOS"), so the wrapper has to hold up there too. Walk the
# symlink chain by hand — POSIX, no coreutils, bash 3.2.
SELF="${BASH_SOURCE[0]}"
while [ -L "$SELF" ]; do
    LINK="$(ls -ld -- "$SELF" 2>/dev/null)"; LINK="${LINK#*" -> "}"
    case "$LINK" in
        /*) SELF="$LINK" ;;                       # absolute: take it as-is
        *)  SELF="$(dirname "$SELF")/$LINK" ;;    # relative: resolve against its dir
    esac
done
HERE="$(cd "$(dirname "$SELF")/.." && pwd)"

# The one dependency `herd doctor` cannot report on, because reporting it means
# already being inside the interpreter that is missing. Unguarded, this exec'd
# straight into `bin/herd: python3: command not found` — the shell's message,
# naming neither herd nor the fix. `command -v` is a builtin: no fork.
if ! command -v python3 >/dev/null 2>&1; then
    echo "herd: python3 not found on PATH (herd needs Python >= 3.9)" >&2
    echo "  the CLI, the daemon and the installer are Python; the hooks are not," >&2
    echo "  so an already-installed herd keeps recording — you just cannot read it." >&2
    exit 127
fi
PYTHONPATH="$HERE/src${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m herd.cli "$@"
